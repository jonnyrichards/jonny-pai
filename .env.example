# Optional - Claude model to use (default: sonnet)
PAI_MODEL=sonnet

# Optional - WhatsApp credentials directory (default: ~/.pai/credentials/whatsapp)
PAI_CREDENTIALS_DIR=~/.pai/credentials/whatsapp

# Optional - Journal log directory (default: ~/.pai/journal)
PAI_JOURNAL_DIR=~/.pai/journal

# Optional - Path to claude CLI binary (default: claude)
PAI_CLAUDE_BIN=claude

# Optional - Max budget per message in USD (default: 1.00)
PAI_MAX_BUDGET=1.00

# Optional - Minutes of idle before session rotation with summarization (default: 30)
PAI_SESSION_IDLE_MINUTES=30

# Optional - OpenAI API key for Whisper transcription and TTS audio responses
OPENAI_API_KEY=sk-...

# Optional - TTS voice for audio responses (default: ash)
# Options: alloy, ash, ballad, coral, echo, fable, onyx, nova, sage, shimmer
PAI_TTS_VOICE=ash

# Optional - TTS model (default: gpt-4o-mini-tts)
PAI_TTS_MODEL=gpt-4o-mini-tts

# Optional - Image generation model (default: gpt-image-1)
PAI_IMAGE_MODEL=gpt-image-1

# Optional - Image generation size (default: 1024x1024)
# Options: 1024x1024, 1536x1024 (landscape), 1024x1536 (portrait)
PAI_IMAGE_SIZE=1024x1024

# Optional - Image generation quality (default: medium)
# Options: low, medium, high
PAI_IMAGE_QUALITY=medium

# Optional - Enable proactive scheduler (default: true)
PAI_SCHEDULER_ENABLED=true

# Optional - Max budget per scheduled task in USD (default: 10.00)
PAI_SCHEDULER_MAX_BUDGET=10.00

# Optional - Timezone for scheduler cron jobs (default: America/New_York)
PAI_TIMEZONE=America/New_York

# Optional - Path to a notes vault (e.g. Obsidian) for vault journaling and nightly scanning
# PAI_NOTES_VAULT=~/my-vault

# Optional - Enable verbose SDK logging (default: false)
# PAI_VERBOSE=true
